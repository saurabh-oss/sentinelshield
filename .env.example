# ── NexusCloud Commerce ────────────────────────────────────────────────────────
NEXUSCLOUD_DB_HOST=postgres
NEXUSCLOUD_DB_PORT=5432
NEXUSCLOUD_DB_NAME=nexuscloud
NEXUSCLOUD_DB_USER=nexus
NEXUSCLOUD_DB_PASSWORD=change_me_nexus

# JWT secret — use a long random string in any real deployment
NEXUSCLOUD_SECRET_KEY=change_me_jwt_secret

# ── SentinelShield Engine ──────────────────────────────────────────────────────
SENTINEL_DB_HOST=postgres
SENTINEL_DB_PORT=5432
SENTINEL_DB_NAME=sentinel
SENTINEL_DB_USER=sentinel
SENTINEL_DB_PASSWORD=change_me_sentinel

SENTINEL_REDIS_URL=redis://redis:6379/0
SENTINEL_NEXUSCLOUD_URL=http://nexuscloud-api:8000
SENTINEL_PROMETHEUS_URL=http://prometheus:9090

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI Resolver Generator ──────────────────────────────────────────────────────
# Optional — only needed for the AI-powered resolver generation feature.
# Get your key at https://console.anthropic.com/
# Without a key, SentinelShield still detects threats and runs built-in resolvers;
# it simply skips automatic code synthesis for unknown threat types.
ANTHROPIC_API_KEY=

# ── Grafana ────────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana
GF_USERS_ALLOW_SIGN_UP=false
